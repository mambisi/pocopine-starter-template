<div class="counter">
  <button class="counter-btn" @click="decrement" aria-label="decrement">&minus;</button>
  <span class="counter-value" pp-text="count"></span>
  <button class="counter-btn" @click="increment" aria-label="increment">+</button>
  <span class="counter-label" pp-text="label"></span>
</div>
